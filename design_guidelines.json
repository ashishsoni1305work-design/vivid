  "pages": {
    "home": {
      "sections": ["Hero (Immersive)", "Trusted By (Logos)", "Bento Grid Products", "Technical Services", "Testimonials"]
    },
    "products": {
      "layout": "Sidebar Filter + Grid",
      "card_style": "Minimalist, Photo-heavy, Tech specs visible"
    },
    "contact": {
      "layout": "Split Screen (Map + Form)",
      "map_style": "Grayscale/Muted custom map style"
    }
  },
  "accessibility": {
    "contrast": "APCA Compliant. Dark text on light bg, White text on dark bg.",
    "focus": "Visible focus rings (2px offset).",
    "aria": "All interactive elements must have aria-labels."
  },
  "universal_guidelines": [
    "Do not use gradients for text.",
    "Do not center align the app container.",
    "Use 'sonner' for toasts.",
    "Use 'data-testid' for all interactive elements.",
    "Mobile images max-h-[80vh].",
    "Avoid generic 'water drop' icons. Use abstract geometric shapes."
  ]
}