{
  "project_name": "Vivid H2O Solutions",
  "theme": "light",
  "design_philosophy": {
    "persona": "E1: The Anti-AI Designer",
    "core_concept": "The Deep Blue Industrialist",
    "description": "A fusion of heavy industrial reliability and the purity of water. High contrast between stainless steel greys and deep ocean blues. It avoids the generic 'corporate blue' by using deeper, richer tones and high-tech mono/geometric typography.",
    "emotional_tone": "Trust, Technical Precision, Industrial Power, Cleanliness",
    "forbidden_elements": [
      "Generic Teal (#1B93A4)",
      "Purple",
      "Gradient Overload",
      "Centered Everything",
      "AI Emoji Icons"
    ]
  },
  "typography": {
    "headings": {
      "font_family": "Manrope, sans-serif",
      "weights": ["600", "800"],
      "description": "Modern, geometric, semi-industrial. Use tight tracking for large headers.",
      "install_command": "yarn add @fontsource/manrope"
    },
    "body": {
      "font_family": "Public Sans, sans-serif",
      "weights": ["400", "500"],
      "description": "Clean, neutral, government-grade legibility.",
      "install_command": "yarn add @fontsource/public-sans"
    },
    "mono": {
      "font_family": "JetBrains Mono, monospace",
      "description": "For technical specs and data points.",
      "install_command": "yarn add @fontsource/jetbrains-mono"
    }
  },
  "colors": {
    "palette": {
      "primary": "#0F172A",
      "primary_foreground": "#F8FAFC",
      "secondary": "#94A3B8",
      "accent": "#06B6D4",
      "accent_foreground": "#FFFFFF",
      "background": "#FFFFFF",
      "surface": "#F1F5F9",
      "muted": "#E2E8F0",
      "border": "#CBD5E1"
    },
    "gradients": {
      "hero_overlay": "linear-gradient(180deg, rgba(15, 23, 42, 0.4) 0%, rgba(15, 23, 42, 0.9) 100%)",
      "glass_surface": "rgba(255, 255, 255, 0.7)"
    }
  },
  "layout_strategy": {
    "spacing": "Generous. Use p-8, p-16, p-24. Avoid cramped p-4.",
    "container_padding": "p-6 or p-8 for bordered containers.",
    "grid_system": "Bento Grid (Asymmetric). Never equal squares for main content.",
    "alignment": "Left-aligned for text. Asymmetric for layout. Optical alignment for icons."
  },
  "components": {
    "buttons": {
      "style": "Sharp edges or minimal rounded-md. No pill shapes for industrial look.",
      "hover": "High contrast lift. scale-105.",
      "variants": ["solid-primary", "outline-heavy", "ghost-accent"]
    },
    "cards": {
      "style": "Flat, 1px border (slate-200), no shadow by default. Shadow-lg on hover.",
      "content": "Must include technical specs in mono font."
    },
    "navigation": {
      "style": "Sticky, Glassmorphism (Backdrop blur-xl). Solid bottom border 1px."
    },
    "forms": {
      "library": "Shadcn UI",
      "style": "Clean, high contrast borders. Focus rings must be sharp."
    }
  },
  "visual_enhancers": {
    "textures": "Subtle noise overlay on dark sections (Footer, Hero).",
    "glassmorphism": "Used for overlays, toasts, and sticky headers. Backdrop-blur-xl.",
    "motion": {
      "library": "Framer Motion",
      "defaults": {
        "duration": 0.4,
        "ease": "easeOut"
      },
      "scroll": "Parallax for hero images. Staggered entrance for product grids."
    },
    "icons": {
      "library": "Lucide React",
      "style": "Stroke width 1.5px. Crisp and technical."
    }
  },
